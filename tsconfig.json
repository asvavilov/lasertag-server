{
  "compilerOptions": {
    "target": "ESNext",           // Используйте современный JS
    "module": "NodeNext",         // или "CommonJS" для совместимости
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",

    // Ключевые оптимизации
    "removeComments": true,        // Удалить комментарии
    "sourceMap": false,            // Отключить source maps в production
    "declaration": false,          // Не генерировать .d.ts файлы
    "incremental": false,          // Отключить инкрементальную компиляцию

    // Оптимизация памяти
    "skipLibCheck": true,          // Пропустить проверку типов в .d.ts
    "skipDefaultLibCheck": true,

    // Производительность выполнения
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
